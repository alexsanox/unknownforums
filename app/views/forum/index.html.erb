<% content_for :title, "Forum Index" %>
<% meta_description "#{forum_name} — Browse categories and subforums." %>
<% meta_keywords [forum_name, "forum", "community", "discussion", "threads"] %>
<% canonical_url root_url %>
<% content_for :structured_data do %>
  <script type="application/ld+json"><%= website_jsonld %></script>
<% end %>

<!-- Welcome bar -->
<div style="background:var(--bg3); border:1px solid var(--border); border-left:3px solid var(--accent); padding:7px 12px; margin-bottom:10px; font-size:11px; color:var(--text-dim); display:flex; justify-content:space-between; align-items:center; border-radius:0 3px 3px 0;">
  <span><strong style="color:var(--text-bright);">Welcome to <%= forum_name %></strong></span>
  <span>
    <% if logged_in? %>
      Welcome back, <a href="<%= user_path(current_user) %>" style="color:var(--accent); font-weight:bold;"><%= current_user.username %></a>
    <% else %>
      <a href="<%= register_path %>" class="btn btn-primary btn-sm">Register</a>
      &nbsp;
      <a href="<%= login_path %>" class="btn btn-sm">Sign in</a>
    <% end %>
  </span>
</div>

<% @categories.each do |category| %>
  <% cat_key = "cat-collapsed-#{category.id}" %>
  <div style="margin-bottom:14px;">
    <table style="border:1px solid var(--border); border-radius:3px; overflow:hidden;" id="cat-table-<%= category.id %>">
      <tr style="background:var(--bg4);">
        <td colspan="4" style="padding:0; border-bottom:1px solid var(--border); border-left:3px solid var(--accent);">
          <button
            onclick="toggleCategory(<%= category.id %>)"
            style="width:100%; background:none; border:none; cursor:pointer; padding:8px 12px; display:flex; align-items:center; justify-content:space-between; gap:8px; text-align:left;"
          >
            <span style="display:flex; align-items:center; gap:8px;">
              <span style="font-size:13px; font-weight:bold; color:var(--text-bright);"><%= category.name %></span>
              <% if category.description.present? %>
                <span style="font-size:10px; color:var(--text-dim); font-weight:normal;"><%= category.description %></span>
              <% end %>
            </span>
            <svg id="cat-chevron-<%= category.id %>" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; transition:transform 0.2s;"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </td>
      </tr>
      <tbody id="cat-body-<%= category.id %>">
        <tr style="background:var(--bg2); font-size:10px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.04em;">
          <th style="width:50%; text-align:left; padding:4px 12px;">Forum</th>
          <th style="width:10%; text-align:center;">Threads</th>
          <th style="width:10%; text-align:center;">Posts</th>
          <th style="width:30%; text-align:left; padding:4px 10px;">Last Post</th>
        </tr>

        <% category.subforums.each_with_index do |subforum, i| %>
          <% last_post = @last_post_by_subforum[subforum.id] %>
          <tr style="background:<%= i.even? ? 'var(--bg3)' : 'var(--bg2)' %>; border-top:1px solid var(--border-dim);">
            <td style="padding:9px 12px;">
              <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:32px; height:32px; background:var(--accent-dim); flex-shrink:0; display:flex; align-items:center; justify-content:center; border-radius:3px; opacity:0.85;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8eef4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div>
                  <a href="<%= subforum_path(subforum) %>" style="font-size:13px; font-weight:bold; color:var(--link-hover);"><%= subforum.name %></a>
                  <% if subforum.description.present? %>
                    <div style="font-size:11px; color:var(--text-dim); margin-top:2px;"><%= subforum.description %></div>
                  <% end %>
                </div>
              </div>
            </td>
            <td style="text-align:center; font-size:12px; color:var(--text);"><%= subforum.threads_count %></td>
            <td style="text-align:center; font-size:12px; color:var(--text);"><%= subforum.posts_count %></td>
            <td style="font-size:11px; color:var(--text-dim); padding:9px 10px;">
              <% if last_post %>
                <div><a href="<%= forum_thread_path(last_post["thread_id"]) %>" style="font-size:11px;"><%= truncate(last_post["thread_title"], length: 40) %></a></div>
                <div style="margin-top:2px; font-size:10px; color:var(--text-muted);">
                  by <a href="<%= user_path(last_post["user_id"]) %>" style="color:var(--text-dim);"><%= last_post["username"] %></a>
                  &mdash; <%= time_ago_in_words(last_post["post_created_at"]) %> ago
                </div>
              <% else %>
                <span style="color:var(--text-muted);">No posts yet</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<script nonce="<%= content_security_policy_nonce %>">
  function toggleCategory(id) {
    var body    = document.getElementById('cat-body-' + id);
    var chevron = document.getElementById('cat-chevron-' + id);
    var key     = 'cat-collapsed-' + id;
    var collapsed = body.style.display === 'none';
    if (collapsed) {
      body.style.display = '';
      chevron.style.transform = '';
      localStorage.removeItem(key);
    } else {
      body.style.display = 'none';
      chevron.style.transform = 'rotate(-90deg)';
      localStorage.setItem(key, '1');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    <% @categories.each do |category| %>
      if (localStorage.getItem('cat-collapsed-<%= category.id %>') === '1') {
        var body    = document.getElementById('cat-body-<%= category.id %>');
        var chevron = document.getElementById('cat-chevron-<%= category.id %>');
        if (body)    body.style.display = 'none';
        if (chevron) chevron.style.transform = 'rotate(-90deg)';
      }
    <% end %>
  });
</script>

<!-- Forum stats bar -->
<div style="background:var(--bg3); border:1px solid var(--border); padding:7px 12px; font-size:11px; color:var(--text-dim); margin-top:4px; display:flex; gap:20px; flex-wrap:wrap; border-radius:3px;">
  <span><span style="color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;">Threads</span> <strong style="color:var(--text); margin-left:4px;"><%= @stats[:threads] %></strong></span>
  <span><span style="color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;">Posts</span> <strong style="color:var(--text); margin-left:4px;"><%= @stats[:posts] %></strong></span>
  <span><span style="color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;">Members</span> <strong style="color:var(--text); margin-left:4px;"><%= @stats[:members] %></strong></span>
  <span><span style="color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;">Files</span> <strong style="color:var(--text); margin-left:4px;"><%= @stats[:files] %></strong></span>
  <span><span style="color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:0.05em;">Downloads</span> <strong style="color:var(--text); margin-left:4px;"><%= @stats[:downloads] %></strong></span>
</div>
