<% content_for :title, "Forum Index" %>
<% meta_description "#{forum_name} — Browse categories and subforums." %>
<% meta_keywords [forum_name, "forum", "community", "discussion", "threads"] %>
<% canonical_url root_url %>
<% content_for :structured_data do %>
  <script type="application/ld+json"><%= website_jsonld %></script>
<% end %>

<!-- Forum stats bar -->
<div style="background:#242424; border:1px solid #444; padding:5px 10px; margin-bottom:8px; font-size:11px; color:#888; display:flex; justify-content:space-between;">
  <span>
    <strong style="color:#cfcfcf;">Welcome to the Forums</strong>
  </span>
  <span>
    <% if logged_in? %>
      Welcome back, <a href="<%= user_path(current_user) %>"><%= current_user.username %></a>
    <% else %>
      <a href="<%= register_path %>">Register</a> or <a href="<%= login_path %>">Login</a>
    <% end %>
  </span>
</div>

<% @categories.each do |category| %>
  <!-- Category block -->
  <div style="margin-bottom:12px;">
    <!-- Category header -->
    <table style="border:1px solid #444;">
      <tr style="background:#303030;">
        <td colspan="4" style="padding:6px 10px; font-size:13px; font-weight:bold; color:#e0e0e0; border-bottom:1px solid #444;">
          <%= category.name %>
          <% if category.description.present? %>
            <span style="font-size:10px; color:#888; font-weight:normal; margin-left:8px;"><%= category.description %></span>
          <% end %>
        </td>
      </tr>
      <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
        <th style="width:50%; text-align:left; padding:3px 10px;">Forum</th>
        <th style="width:10%; text-align:center;">Threads</th>
        <th style="width:10%; text-align:center;">Posts</th>
        <th style="width:30%; text-align:left;">Last Post</th>
      </tr>

      <% category.subforums.each_with_index do |subforum, i| %>
        <% last_post = @last_post_by_subforum[subforum.id] %>
        <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
          <td style="padding:8px 10px;">
            <div style="display:flex; align-items:flex-start; gap:8px;">
              <div style="width:36px; height:28px; background:#303030; border:1px solid #444; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:9px; color:#888; font-weight:bold;">
                FORUM
              </div>
              <div>
                <a href="<%= subforum_path(subforum) %>" style="font-size:13px; font-weight:bold; color:#a8c8f0;"><%= subforum.name %></a>
                <% if subforum.description.present? %>
                  <div style="font-size:11px; color:#888; margin-top:2px;"><%= subforum.description %></div>
                <% end %>
              </div>
            </div>
          </td>
          <td style="text-align:center; font-size:12px; color:#cfcfcf;"><%= subforum.threads_count %></td>
          <td style="text-align:center; font-size:12px; color:#cfcfcf;"><%= subforum.posts_count %></td>
          <td style="font-size:11px; color:#888;">
            <% if last_post %>
              <div><a href="<%= forum_thread_path(last_post["thread_id"]) %>" style="color:#7aabde; font-size:11px;"><%= truncate(last_post["thread_title"], length: 40) %></a></div>
              <div style="margin-top:2px;">
                by <a href="<%= user_path(last_post["user_id"]) %>"><%= last_post["username"] %></a>
                &mdash; <%= time_ago_in_words(last_post["post_created_at"]) %> ago
              </div>
            <% else %>
              <span style="color:#555;">No posts yet</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
<% end %>

<!-- Forum stats footer -->
<div style="background:#242424; border:1px solid #444; padding:6px 10px; font-size:11px; color:#888; margin-top:4px;">
  <strong style="color:#cfcfcf;">Forum Statistics:</strong>
  Threads: <strong><%= @stats[:threads] %></strong> &nbsp;|&nbsp;
  Posts: <strong><%= @stats[:posts] %></strong> &nbsp;|&nbsp;
  Members: <strong><%= @stats[:members] %></strong> &nbsp;|&nbsp;
  Files: <strong><%= @stats[:files] %></strong> &nbsp;|&nbsp;
  Downloads: <strong><%= @stats[:downloads] %></strong>
</div>
