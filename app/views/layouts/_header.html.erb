<div style="background:#242424; border-bottom:2px solid #444; padding:0;">
  <% if logged_in? %>
    <%= turbo_stream_from current_user, :message_badge %>
  <% end %>
  <!-- Forum banner -->
  <div class="site-banner">
    <a href="<%= root_path %>">
      <%= image_tag "unknown-forums-banner.png", alt: "Forums" %>
    </a>
  </div>

  <!-- Navigation tabs -->
  <div class="header-inner" style="display:flex; align-items:flex-end; justify-content:space-between; gap:8px;">
    <div class="nav-tabs" style="flex:1;">
      <a href="<%= root_path %>">Home</a>
      <a href="<%= root_path %>">Forum</a>
      <a href="<%= downloads_path %>">Downloads</a>
      <a href="<%= leaderboard_path %>">Leaderboard</a>
      <% if logged_in? %>
        <a href="<%= private_messages_path %>">Messages</a>
        <a href="<%= my_downloads_path %>">My Downloads</a>
        <a href="<%= user_path(current_user) %>">Profile</a>
      <% end %>
    </div>
    <%= form_with url: search_path, method: :get, style: "display:flex; align-items:center; gap:4px; padding-bottom:4px;" do |f| %>
      <%= f.text_field :q, placeholder: "Search…",
            style: "width:160px; font-size:11px; padding:3px 6px; background:#1b1b1b; border:1px solid #444; color:#cfcfcf;",
            autocomplete: "off" %>
      <button type="submit" style="background:#2a2a2a; border:1px solid #444; color:#888; padding:3px 8px; font-size:11px; cursor:pointer;">Search</button>
    <% end %>
  </div>

  <!-- User toolbar -->
  <div class="user-toolbar">
    <div class="header-inner user-toolbar-row">
      <span style="color:#666; font-size:10px;">
        <%= Time.current.strftime("%A, %B %d, %Y %H:%M") %> UTC
      </span>
      <div class="top-links">
        <% if logged_in? %>
          <span>Logged in as <a href="<%= user_path(current_user) %>" style="color:#7aabde;"><strong><%= current_user.username %></strong></a></span>
          <a href="<%= private_messages_path %>">Messages
            <%= render "private_messages/message_badge", user: current_user %>
          </a>
          <% _unread_notif = current_user.unread_notifications_count %>
          <a href="<%= notifications_path %>" style="position:relative; white-space:nowrap; text-decoration:none;">
            Watched
            <% if _unread_notif > 0 %>
              <span style="background:#7aabde; color:#000; border-radius:10px; padding:0 5px; font-size:9px; font-weight:bold; margin-left:2px;"><%= _unread_notif > 99 ? '99+' : _unread_notif %></span>
            <% end %>
          </a>
          <a href="<%= user_path(current_user) %>">Profile</a>
          <% if current_user.can_moderate? %>
            <a href="<%= admin_root_path %>" style="color:#f0c060;">Admin Panel</a>
          <% end %>
          <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-muted btn-sm", data: { turbo: false } %>
        <% else %>
          <a href="<%= login_path %>">Login</a>
          <a href="<%= register_path %>">Register</a>
        <% end %>
      </div>
    </div>
  </div>
</div>
