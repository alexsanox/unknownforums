<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} - #{forum_name}" : forum_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <meta name="description" content="<%= content_for(:meta_description).presence || forum_description %>">
    <% if content_for?(:meta_keywords) %><meta name="keywords" content="<%= content_for(:meta_keywords) %>"><% end %>
    <% if content_for?(:robots) %><meta name="robots" content="<%= content_for(:robots) %>"><% else %><meta name="robots" content="index, follow"><% end %>
    <% if content_for?(:canonical_url) %><link rel="canonical" href="<%= content_for(:canonical_url) %>"><% end %>
    <meta property="og:site_name" content="<%= forum_name %>">
    <meta property="og:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || forum_name %>">
    <meta property="og:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || forum_description %>">
    <meta property="og:type" content="<%= content_for(:og_type).presence || 'website' %>">
    <% if content_for?(:og_image) %><meta property="og:image" content="<%= content_for(:og_image) %>"><% end %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || forum_name %>">
    <meta name="twitter:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || forum_description %>">
    <link rel="icon" href="/favis/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favis/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favis/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/favis/apple-touch-icon.png">
    <link rel="manifest" href="/favis/site.webmanifest">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { box-sizing: border-box; }
      body {
        background: #1b1b1b;
        color: #cfcfcf;
        font-family: Verdana, Arial, sans-serif;
        font-size: 12px;
        margin: 0;
        padding: 0;
      }
      a { color: #7aabde; text-decoration: none; }
      a:hover { text-decoration: underline; color: #a8c8f0; }
      table { border-collapse: collapse; width: 100%; }
      td, th { padding: 4px 8px; vertical-align: middle; }
      input[type="text"], input[type="email"], input[type="password"], input[type="number"], textarea, select {
        background: #1b1b1b;
        border: 1px solid #444;
        color: #cfcfcf;
        padding: 4px 6px;
        font-family: Verdana, Arial, sans-serif;
        font-size: 12px;
      }
      input[type="text"]:focus, input[type="email"]:focus, input[type="password"]:focus, input[type="number"]:focus, textarea:focus, select:focus {
        border-color: #7aabde;
        outline: none;
      }
      label { font-size: 10px; color: #888; }
      .btn {
        background: linear-gradient(#383838, #2c2c2c);
        border: 1px solid #555;
        border-radius: 2px;
        color: #cfcfcf;
        cursor: pointer;
        font-family: Verdana, Arial, sans-serif;
        font-size: 11px;
        line-height: 1;
        padding: 5px 10px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        white-space: nowrap;
      }
      .btn:hover { background: linear-gradient(#444, #333); border-color: #777; box-shadow: inset 0 1px 0 rgba(255,255,255,0.05); text-decoration: none; color: #fff; }
      .btn-primary { background: linear-gradient(#244a78, #1b3558); border-color: #2f5d94; color: #c0d8f0; }
      .btn-primary:hover { background: linear-gradient(#2d5b92, #22446e); color: #d7e8f8; }
      .btn-danger { background: linear-gradient(#692222, #501818); border-color: #8a2020; color: #f0a0a0; }
      .btn-danger:hover { background: linear-gradient(#812828, #651d1d); color: #ffd0d0; }
      .btn-success { background: linear-gradient(#214d21, #183818); border-color: #2f6b2f; color: #9bd89b; }
      .btn-success:hover { background: linear-gradient(#2b622b, #204b20); color: #c0f0c0; }
      .btn-muted { background: transparent; border-color: #3f3f3f; color: #999; }
      .btn-sm { padding: 4px 7px; font-size: 10px; }
      .btn-block { width: 100%; }
      .action-group { display: inline-flex; align-items: center; gap: 4px; flex-wrap: wrap; }
      .action-group form { margin: 0; display: inline-flex; }
      .action-stack { display: flex; flex-direction: column; gap: 6px; }
      .action-stack form { margin: 0; display: flex; }
      .action-stack form .btn { width: 100%; }
      .panel { background: #242424; border: 1px solid #444; }
      .panel-header { background: #303030; border-bottom: 1px solid #444; color: #e0e0e0; display: flex; justify-content: space-between; align-items: center; gap: 8px; padding: 7px 10px; font-size: 12px; font-weight: bold; }
      .panel-body { padding: 10px; }
      .toolbar { background: #222; border: 1px solid #444; padding: 6px 10px; font-size: 11px; color: #888; display: flex; justify-content: space-between; align-items: center; gap: 8px; }
      .admin-summary { margin-bottom: 12px; }
      .admin-stats { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; margin-bottom: 8px; }
      .admin-stat-card { background: #242424; border: 1px solid #444; padding: 10px; text-align: center; }
      .admin-stat-value { color: #a8c8f0; font-size: 24px; font-weight: bold; line-height: 1; margin-bottom: 4px; }
      .admin-stat-label { color: #888; font-size: 11px; }
      .admin-quick-links { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
      .admin-search-form { display: flex; align-items: flex-end; gap: 8px; flex-wrap: wrap; width: 100%; }
      .admin-search-field { display: flex; flex-direction: column; gap: 3px; margin: 0; }
      .admin-search-field.grow { flex: 1; min-width: 240px; }
      .admin-search-field input, .admin-search-field select { height: 28px; }
      .admin-search-actions { display: flex; align-items: center; gap: 6px; margin-left: auto; }
      .badge { border: 1px solid #555; background: #3a3a3a; color: #aaa; font-size: 9px; padding: 1px 5px; margin-left: 6px; text-transform: uppercase; }
      .badge-pin { background: #4a3a00; border-color: #6a5a00; color: #f0c060; }
      .badge-admin { background: #4a1a1a; border-color: #7a3030; color: #ff9a9a; }
      .badge-moderator { background: #1a304a; border-color: #305a7a; color: #9ac8ff; }
      .post-actions { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
      .post-actions a { color: #aaa; border: 1px solid transparent; padding: 2px 5px; }
      .post-actions a:hover { background: #303030; border-color: #444; text-decoration: none; color: #d8d8d8; }
      /* UC-style post layout */
      .uc-post { display: flex; border-top: 1px solid #444; }
      .uc-post:first-child { border-top: none; }
      .uc-post-user { width: 175px; min-width: 175px; background: #1e1e1e; border-right: 1px solid #444; padding: 8px 10px; text-align: center; }
      .uc-post-user .uc-username { font-size: 12px; font-weight: bold; }
      .uc-post-user .uc-username a { color: #a8c8f0; }
      .uc-post-user .uc-rank { font-size: 10px; color: #888; margin-top: 1px; }
      .uc-post-user .uc-avatar { width: 80px; height: 80px; background: #303030; border: 1px solid #444; margin: 6px auto; overflow: hidden; display: flex; align-items: center; justify-content: center; }
      .uc-post-user .uc-avatar img { width: 100%; height: 100%; object-fit: cover; }
      .uc-post-user .uc-info-row { font-size: 10px; color: #888; margin-top: 3px; text-align: left; display: flex; justify-content: space-between; }
      .uc-post-user .uc-info-label { color: #666; }
      .uc-post-user .uc-rep-desc { font-size: 9px; color: #777; margin-top: 4px; font-style: italic; }
      .uc-post-user .uc-section { margin-top: 6px; padding-top: 6px; border-top: 1px solid #333; }
      .uc-post-user .uc-progress-row { display: flex; align-items: center; gap: 4px; margin-top: 3px; font-size: 9px; color: #888; }
      .uc-progress-bar { flex: 1; height: 6px; background: #333; border: 1px solid #444; overflow: hidden; }
      .uc-progress-fill { height: 100%; background: #4a6a8a; }
      .uc-progress-fill.activity { background: #6a8a4a; }
      .uc-post-content { flex: 1; display: flex; flex-direction: column; min-width: 0; }
      .uc-post-header { background: #2a2a2a; border-bottom: 1px solid #333; padding: 4px 10px; display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: #666; }
      .uc-post-body { padding: 10px; font-size: 12px; line-height: 1.6; flex: 1; }
      .uc-post-sig { border-top: 1px dashed #333; padding: 6px 10px; font-size: 10px; color: #555; }
      .uc-post-footer { border-top: 1px solid #333; padding: 4px 10px; display: flex; justify-content: space-between; align-items: center; }
      .uc-quote { background: #1a1a1a; border-left: 3px solid #444; padding: 8px 10px; margin: 0 0 8px 0; font-size: 11px; color: #888; }
      .uc-quote-header { font-size: 10px; color: #666; margin-bottom: 4px; }
      .uc-user-online { display: inline-block; width: 7px; height: 7px; background: #60c060; border-radius: 50%; margin-left: 3px; }
      .uc-user-offline { display: inline-block; width: 7px; height: 7px; background: #555; border-radius: 50%; margin-left: 3px; }
      .form-row { margin-bottom: 9px; }
      .form-row label { display: block; margin-bottom: 3px; }
      .top-links { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; color: #888; }
      .top-links form { margin: 0; display: inline-flex; }
      .header-inner { max-width: 1100px; margin: 0 auto; padding: 0 8px; }
      .header-inner-flush { max-width: 1100px; margin: 0 auto; padding: 0; }
      .user-toolbar { background: #1b1b1b; border-top: 1px solid #333; border-bottom: 1px solid #444; font-size: 11px; }
      .user-toolbar-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; padding: 4px 0 4px 8px; }
      .site-banner { width: 100%; aspect-ratio: 4480 / 770; max-height: 190px; overflow: hidden; background: #070707; border-bottom: 1px solid #333; line-height: 0; }
      .site-banner a { display: block; width: min(100%, 1100px); height: 100%; }
      .site-banner img { display: block; width: 100%; height: auto; }
      .nav-tabs { display: flex; gap: 2px; border-bottom: 1px solid #444; padding-left: 0; }
      .nav-tabs a { background: #1b1b1b; border: 1px solid #444; border-bottom: none; color: #cfcfcf; padding: 6px 13px; font-size: 11px; }
      .nav-tabs a:hover { background: #242424; color: #fff; text-decoration: none; }
      .content-shell { max-width: 1100px; margin: 0 auto; padding: 10px 8px; }
      .flash-notice { background: #1a3a1a; border: 1px solid #2a5a2a; color: #80c080; padding: 6px 10px; margin-bottom: 8px; font-size: 11px; }
      .flash-alert { background: #3a1a1a; border: 1px solid #6a2a2a; color: #f08080; padding: 6px 10px; margin-bottom: 8px; font-size: 11px; }
      .field_with_errors input, .field_with_errors textarea { border-color: #c04040; }
      .error-list { color: #f08080; font-size: 11px; margin: 4px 0; padding-left: 16px; }
      @media (max-width: 900px) {
        .admin-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .panel-header, .toolbar { align-items: flex-start; flex-direction: column; }
        .nav-tabs { flex-wrap: wrap; }
      }
      @media (max-width: 640px) {
        .top-links { gap: 6px; }
        .admin-stats { grid-template-columns: 1fr; }
        .admin-search-field.grow, .admin-search-actions { width: 100%; margin-left: 0; }
        .admin-search-actions .btn { flex: 1; }
        .user-toolbar-row { align-items: flex-start; flex-direction: column; }
        .content-shell { padding: 8px 6px; overflow-x: auto; }
        td, th { padding: 4px 5px; }
        .uc-post { flex-direction: column; }
        .uc-post-user { width: 100%; min-width: 0; border-right: none; border-bottom: 1px solid #444; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; justify-content: center; padding: 6px; }
        .uc-post-user .uc-avatar { width: 50px; height: 50px; margin: 0; }
        .uc-post-user .uc-section { border-top: none; margin-top: 0; padding-top: 0; }
      }
    </style>
    <% if content_for?(:structured_data) %><%= content_for(:structured_data) %><% end %>
  </head>
  <body>
    <%= render "layouts/header" %>

    <div class="content-shell">
      <% if flash[:notice] %>
        <div class="flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-alert"><%= flash[:alert] %></div>
      <% end %>
      <% if @admin_summary.present? && controller_path.start_with?("admin/") %>
        <%= render "admin/shared/dashboard_summary" %>
      <% end %>

      <%= yield %>
    </div>

    <%= render "layouts/footer" %>
  </body>
</html>
