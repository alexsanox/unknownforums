<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} - #{forum_name}" : forum_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <meta name="description" content="<%= content_for(:meta_description).presence || forum_description %>">
    <% if content_for?(:meta_keywords) %><meta name="keywords" content="<%= content_for(:meta_keywords) %>"><% end %>
    <% if content_for?(:robots) %><meta name="robots" content="<%= content_for(:robots) %>"><% else %><meta name="robots" content="index, follow"><% end %>
    <% if content_for?(:canonical_url) %><link rel="canonical" href="<%= content_for(:canonical_url) %>"><% end %>
    <meta property="og:site_name" content="<%= forum_name %>">
    <meta property="og:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || forum_name %>">
    <meta property="og:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || forum_description %>">
    <meta property="og:type" content="<%= content_for(:og_type).presence || 'website' %>">
    <% if content_for?(:og_image) %><meta property="og:image" content="<%= content_for(:og_image) %>"><% end %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:og_title).presence || content_for(:title).presence || forum_name %>">
    <meta name="twitter:description" content="<%= content_for(:og_description).presence || content_for(:meta_description).presence || forum_description %>">
    <link rel="icon" href="/favis/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favis/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favis/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/favis/apple-touch-icon.png">
    <link rel="manifest" href="/favis/site.webmanifest">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      :root {
        --accent:       #3d9faf;
        --accent-dim:   #2a7080;
        --accent-glow:  rgba(61,159,175,0.12);
        --bg:           #181818;
        --bg2:          #202020;
        --bg3:          #252525;
        --bg4:          #2c2c2c;
        --border:       #383838;
        --border-dim:   #2e2e2e;
        --text:         #d0d0d0;
        --text-dim:     #888;
        --text-muted:   #555;
        --text-bright:  #efefef;
        --link:         #4fb8c8;
        --link-hover:   #7fd4e0;
        --danger:       #c04040;
        --success:      #3a8a3a;
        --warn:         #b07820;
      }
      * { box-sizing: border-box; }
      body { background: var(--bg); color: var(--text); font-family: Verdana, Arial, sans-serif; font-size: 12px; margin: 0; padding: 0; }
      a { color: var(--link); text-decoration: none; }
      a:hover { color: var(--link-hover); text-decoration: underline; }
      table { border-collapse: collapse; width: 100%; }
      td, th { padding: 4px 8px; vertical-align: middle; }
      input[type="text"], input[type="email"], input[type="password"], input[type="number"], textarea, select {
        background: #141414;
        border: 1px solid var(--border);
        color: var(--text);
        padding: 5px 7px;
        font-family: Verdana, Arial, sans-serif;
        font-size: 12px;
        transition: border-color 0.15s;
      }
      input[type="text"]:focus, input[type="email"]:focus, input[type="password"]:focus,
      input[type="number"]:focus, textarea:focus, select:focus {
        border-color: var(--accent);
        outline: none;
        box-shadow: 0 0 0 2px var(--accent-glow);
      }
      label { font-size: 10px; color: var(--text-dim); }

      /* ── Buttons ── */
      .btn {
        background: var(--bg4);
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text);
        cursor: pointer;
        font-family: Verdana, Arial, sans-serif;
        font-size: 11px;
        line-height: 1;
        padding: 5px 11px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        white-space: nowrap;
        transition: background 0.12s, border-color 0.12s, color 0.12s;
      }
      .btn:hover { background: #363636; border-color: #555; color: var(--text-bright); text-decoration: none; }
      .btn-primary { background: var(--accent-dim); border-color: var(--accent); color: #c8eef4; }
      .btn-primary:hover { background: var(--accent); color: #fff; border-color: #5ecfdf; }
      .btn-danger { background: #3a1a1a; border-color: #6a2828; color: #f09090; }
      .btn-danger:hover { background: #4d2020; color: #ffc0c0; border-color: #8a3030; }
      .btn-success { background: #1a3a1a; border-color: #2d622d; color: #80d080; }
      .btn-success:hover { background: #224a22; color: #a8f0a8; border-color: #3a803a; }
      .btn-muted { background: transparent; border-color: var(--border-dim); color: var(--text-dim); }
      .btn-muted:hover { background: var(--bg3); color: var(--text); }
      .btn-sm { padding: 3px 8px; font-size: 10px; }
      .btn-block { width: 100%; }
      .action-group { display: inline-flex; align-items: center; gap: 4px; flex-wrap: wrap; }
      .action-group form { margin: 0; display: inline-flex; }
      .action-stack { display: flex; flex-direction: column; gap: 6px; }
      .action-stack form { margin: 0; display: flex; }
      .action-stack form .btn { width: 100%; }

      /* ── Panels ── */
      .panel { background: var(--bg3); border: 1px solid var(--border); border-radius: 3px; overflow: hidden; }
      .panel-header {
        background: var(--bg4);
        border-bottom: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        color: var(--text-bright);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        font-size: 12px;
        font-weight: bold;
        letter-spacing: 0.02em;
      }
      .panel-body { padding: 10px; }

      /* ── Toolbar ── */
      .toolbar {
        background: var(--bg2);
        border: 1px solid var(--border);
        padding: 5px 10px;
        font-size: 11px;
        color: var(--text-dim);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
      }

      /* ── Admin ── */
      .admin-summary { margin-bottom: 12px; }
      .admin-stats { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; margin-bottom: 8px; }
      .admin-stat-card { background: var(--bg3); border: 1px solid var(--border); border-top: 2px solid var(--accent-dim); padding: 10px; text-align: center; border-radius: 3px; }
      .admin-stat-value { color: var(--accent); font-size: 24px; font-weight: bold; line-height: 1; margin-bottom: 4px; }
      .admin-stat-label { color: var(--text-dim); font-size: 11px; }
      .admin-quick-links { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
      .admin-search-form { display: flex; align-items: flex-end; gap: 8px; flex-wrap: wrap; width: 100%; }
      .admin-search-field { display: flex; flex-direction: column; gap: 3px; margin: 0; }
      .admin-search-field.grow { flex: 1; min-width: 240px; }
      .admin-search-field input, .admin-search-field select { height: 28px; }
      .admin-search-actions { display: flex; align-items: center; gap: 6px; margin-left: auto; }

      /* ── Badges ── */
      .badge { border: 1px solid #484848; background: var(--bg4); color: #aaa; font-size: 9px; padding: 1px 6px; margin-left: 4px; text-transform: uppercase; letter-spacing: 0.05em; border-radius: 2px; }
      .badge-pin { background: #2e2000; border-color: #5a4000; color: #d4a830; }
      .badge-admin { background: #2e0a0a; border-color: #6a2222; color: #f08080; }
      .badge-moderator { background: #0a1e2e; border-color: #1e4a6a; color: #80c0f0; }

      /* ── Post actions ── */
      .post-actions { display: flex; align-items: center; gap: 3px; flex-wrap: wrap; }
      .post-actions a { color: var(--text-dim); border: 1px solid transparent; padding: 2px 6px; border-radius: 2px; font-size: 10px; }
      .post-actions a:hover { background: var(--bg4); border-color: var(--border); text-decoration: none; color: var(--text-bright); }

      /* ── Post layout ── */
      .uc-post { display: flex; border-top: 1px solid var(--border-dim); }
      .uc-post:first-child { border-top: none; }
      .uc-post-user {
        width: 168px;
        min-width: 168px;
        background: #1d1d1d;
        border-right: 1px solid var(--border-dim);
        padding: 10px 8px;
        text-align: center;
      }
      .uc-post-user .uc-username { font-size: 12px; font-weight: bold; }
      .uc-post-user .uc-username a { color: var(--link-hover); }
      .uc-post-user .uc-rank { font-size: 10px; color: var(--text-dim); margin-top: 2px; }
      .uc-post-user .uc-avatar {
        width: 78px; height: 78px;
        background: var(--bg4);
        border: 1px solid var(--border);
        margin: 7px auto;
        overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        border-radius: 3px;
      }
      .uc-post-user .uc-avatar img { width: 100%; height: 100%; object-fit: cover; }
      .uc-post-user .uc-info-row { font-size: 10px; color: var(--text-dim); margin-top: 3px; text-align: left; display: flex; justify-content: space-between; }
      .uc-post-user .uc-info-label { color: var(--text-muted); }
      .uc-post-user .uc-rep-desc { font-size: 9px; color: #666; margin-top: 4px; font-style: italic; }
      .uc-post-user .uc-section { margin-top: 6px; padding-top: 6px; border-top: 1px solid var(--border-dim); }
      .uc-post-user .uc-progress-row { display: flex; align-items: center; gap: 4px; margin-top: 3px; font-size: 9px; color: var(--text-dim); }
      .uc-progress-bar { flex: 1; height: 4px; background: #2a2a2a; border-radius: 2px; overflow: hidden; }
      .uc-progress-fill { height: 100%; background: var(--accent-dim); border-radius: 2px; }
      .uc-progress-fill.activity { background: #3a7a3a; }
      .uc-post-content { flex: 1; display: flex; flex-direction: column; min-width: 0; }
      .uc-post-header {
        background: #1f1f1f;
        border-bottom: 1px solid var(--border-dim);
        padding: 4px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 10px;
        color: var(--text-muted);
      }
      .uc-post-body { padding: 10px 12px; font-size: 12px; line-height: 1.7; flex: 1; }
      .uc-post-sig { border-top: 1px dashed var(--border-dim); padding: 5px 12px; font-size: 10px; color: var(--text-muted); }
      .uc-post-footer { border-top: 1px solid var(--border-dim); padding: 5px 10px; display: flex; justify-content: space-between; align-items: center; background: #1d1d1d; }
      .uc-quote { background: #161616; border-left: 3px solid var(--accent-dim); padding: 8px 10px; margin: 0 0 8px 0; font-size: 11px; color: #888; border-radius: 0 2px 2px 0; }
      .uc-quote-header { font-size: 10px; color: var(--text-muted); margin-bottom: 4px; }

      /* ── Markdown ── */
      .markdown-body { color: var(--text); line-height: 1.7; word-wrap: break-word; }
      .markdown-body h1,.markdown-body h2,.markdown-body h3,.markdown-body h4,.markdown-body h5,.markdown-body h6 { border-bottom: 1px solid var(--border-dim); color: var(--text-bright); line-height: 1.3; margin: 16px 0 8px; padding-bottom: 4px; }
      .markdown-body h1 { font-size: 20px; } .markdown-body h2 { font-size: 17px; } .markdown-body h3 { font-size: 14px; }
      .markdown-body h4,.markdown-body h5,.markdown-body h6 { font-size: 12px; }
      .markdown-body p,.markdown-body blockquote,.markdown-body ul,.markdown-body ol,.markdown-body table,.markdown-body pre { margin: 0 0 12px; }
      .markdown-body ul,.markdown-body ol { padding-left: 22px; }
      .markdown-body li { margin: 3px 0; }
      .markdown-body blockquote { background: #161616; border-left: 3px solid var(--accent-dim); color: #999; padding: 8px 10px; border-radius: 0 2px 2px 0; }
      .markdown-body code { background: #131313; border: 1px solid #2e2e2e; border-radius: 2px; color: #d0b060; font-family: Consolas, Monaco, monospace; font-size: 11px; padding: 1px 4px; }
      .markdown-body pre { background: #111; border: 1px solid #2e2e2e; overflow-x: auto; padding: 10px 12px; border-radius: 2px; }
      .markdown-body pre code { background: transparent; border: 0; color: #c8c8c8; display: block; padding: 0; white-space: pre; }
      .markdown-body table { border: 1px solid var(--border); border-collapse: collapse; display: block; max-width: 100%; overflow-x: auto; width: max-content; }
      .markdown-body th,.markdown-body td { border: 1px solid var(--border); padding: 6px 8px; }
      .markdown-body th { background: var(--bg4); color: var(--text-bright); font-weight: bold; }
      .markdown-body tr:nth-child(even) td { background: var(--bg2); }
      .markdown-body hr { border: 0; border-top: 1px solid var(--border-dim); margin: 16px 0; }
      .markdown-body a { color: var(--link); }
      .mention { color: var(--accent) !important; font-weight: bold; background: rgba(61,159,175,0.1); padding: 0 3px; border-radius: 2px; }
      .mention:hover { background: rgba(61,159,175,0.2); text-decoration: none; }

      /* ── Online indicators ── */
      .uc-user-online { display: inline-block; width: 7px; height: 7px; background: #50c050; border-radius: 50%; margin-left: 3px; }
      .uc-user-offline { display: inline-block; width: 7px; height: 7px; background: #444; border-radius: 50%; margin-left: 3px; }

      /* ── Forms ── */
      .form-row { margin-bottom: 10px; }
      .form-row label { display: block; margin-bottom: 3px; }

      /* ── Header / Nav ── */
      .top-links { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; color: var(--text-dim); }
      .top-links a { color: var(--text-dim); font-size: 11px; }
      .top-links a:hover { color: var(--text-bright); text-decoration: none; }
      .top-links form { margin: 0; display: inline-flex; }
      .header-inner { max-width: 1100px; margin: 0 auto; padding: 0 10px; }
      .header-inner-flush { max-width: 1100px; margin: 0 auto; padding: 0; }
      .user-toolbar { background: #141414; border-top: 1px solid var(--border-dim); border-bottom: 1px solid var(--border); font-size: 11px; }
      .user-toolbar-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; padding: 5px 0; }
      .site-banner { width: 100%; aspect-ratio: 4480 / 770; max-height: 190px; overflow: hidden; background: #080808; border-bottom: 1px solid var(--border-dim); line-height: 0; }
      .site-banner a { display: block; width: min(100%, 1100px); height: 100%; }
      .site-banner img { display: block; width: 100%; height: auto; }
      .nav-tabs { display: flex; gap: 1px; border-bottom: 1px solid var(--border); }
      .nav-tabs a { background: #141414; border: 1px solid transparent; border-bottom: none; color: var(--text-dim); padding: 7px 14px; font-size: 11px; letter-spacing: 0.02em; transition: background 0.12s, color 0.12s; }
      .nav-tabs a:hover { background: var(--bg3); color: var(--text-bright); text-decoration: none; }
      .nav-tabs a.active { background: var(--bg3); color: var(--accent); border-color: var(--border); border-bottom-color: var(--bg3); }
      .content-shell { max-width: 1100px; margin: 0 auto; padding: 12px 10px; }

      /* ── Flash ── */
      .flash-notice { background: #0f2a0f; border: 1px solid #1f4a1f; border-left: 3px solid #3a8a3a; color: #80d080; padding: 7px 12px; margin-bottom: 10px; font-size: 11px; border-radius: 2px; }
      .flash-alert  { background: #2a0f0f; border: 1px solid #4a1f1f; border-left: 3px solid #8a3030; color: #f08080; padding: 7px 12px; margin-bottom: 10px; font-size: 11px; border-radius: 2px; }
      .field_with_errors input, .field_with_errors textarea { border-color: var(--danger); }
      .error-list { color: #f08080; font-size: 11px; margin: 4px 0; padding-left: 16px; }

      /* ── Modal ── */
      .site-modal-backdrop { align-items: center; background: rgba(0,0,0,0.78); bottom: 0; display: none; justify-content: center; left: 0; padding: 16px; position: fixed; right: 0; top: 0; z-index: 9999; }
      .site-modal-backdrop.active { display: flex; }
      .site-modal { background: var(--bg3); border: 1px solid #505050; box-shadow: 0 16px 48px rgba(0,0,0,0.6); max-width: 420px; width: 100%; border-radius: 4px; overflow: hidden; }
      .site-modal-header { background: var(--bg4); border-bottom: 1px solid var(--border); border-left: 3px solid var(--accent); color: var(--text-bright); font-size: 12px; font-weight: bold; padding: 9px 12px; }
      .site-modal-body { color: var(--text); font-size: 12px; line-height: 1.6; padding: 14px 14px; white-space: pre-wrap; }
      .site-modal-actions { border-top: 1px solid var(--border-dim); display: flex; gap: 8px; justify-content: flex-end; padding: 10px 12px; background: #1f1f1f; }

      /* ── Responsive ── */
      @media (max-width: 900px) {
        .admin-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .panel-header, .toolbar { align-items: flex-start; flex-direction: column; }
        .nav-tabs { flex-wrap: wrap; }
      }
      @media (max-width: 640px) {
        .top-links { gap: 8px; }
        .admin-stats { grid-template-columns: 1fr; }
        .admin-search-field.grow, .admin-search-actions { width: 100%; margin-left: 0; }
        .admin-search-actions .btn { flex: 1; }
        .user-toolbar-row { align-items: flex-start; flex-direction: column; }
        .content-shell { padding: 8px 6px; overflow-x: auto; }
        td, th { padding: 4px 5px; }
        .uc-post { flex-direction: column; }
        .uc-post-user { width: 100%; min-width: 0; border-right: none; border-bottom: 1px solid var(--border); display: flex; flex-wrap: wrap; gap: 8px; align-items: center; padding: 8px; }
        .uc-post-user .uc-avatar { width: 48px; height: 48px; margin: 0; }
        .uc-post-user .uc-section { border-top: none; margin-top: 0; padding-top: 0; }
      }
    </style>
    <% if content_for?(:structured_data) %><%= content_for(:structured_data) %><% end %>
  </head>
  <body>
    <%= render "layouts/header" %>

    <div class="content-shell">
      <% if flash[:notice] %>
        <div class="flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-alert"><%= flash[:alert] %></div>
      <% end %>
      <% if @admin_summary.present? && controller_path.start_with?("admin/") %>
        <%= render "admin/shared/dashboard_summary" %>
      <% end %>

      <%= yield %>
    </div>

    <div id="site-confirm-modal" class="site-modal-backdrop" aria-hidden="true">
      <div class="site-modal" role="dialog" aria-modal="true" aria-labelledby="site-confirm-title">
        <div id="site-confirm-title" class="site-modal-header">Confirm action</div>
        <div id="site-confirm-message" class="site-modal-body"></div>
        <div class="site-modal-actions">
          <button type="button" id="site-confirm-cancel" class="btn">Cancel</button>
          <button type="button" id="site-confirm-ok" class="btn btn-danger">Confirm</button>
        </div>
      </div>
    </div>

    <%= render "layouts/footer" %>
  </body>
</html>
