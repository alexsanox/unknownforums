<div id="reactions-<%= post.id %>" style="display:flex; gap:4px; flex-wrap:wrap; margin-top:4px;">
  <% PostReaction::EMOJIS.each do |emoji| %>
    <% count = post.reactions.count { |r| r.emoji == emoji } %>
    <% reacted = logged_in? && post.reactions.any? { |r| r.emoji == emoji && r.user_id == current_user.id } %>
    <%= button_to post_reactions_path(post_id: post.id, emoji: emoji),
          method: :post,
          class: "btn btn-sm",
          style: "padding:1px 6px; font-size:13px; #{reacted ? 'background:#2a3a4a; border-color:#7aabde;' : ''}",
          form: { data: { turbo_stream: true } } do %>
      <%= emoji %><% if count > 0 %><span style="font-size:10px; margin-left:2px; color:#888;"><%= count %></span><% end %>
    <% end %>
  <% end %>
</div>
