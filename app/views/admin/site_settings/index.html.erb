<% content_for :title, "Site Settings" %>

<div style="max-width:500px;">
  <div class="panel">
    <div class="panel-header">Maintenance Mode</div>
    <div class="panel-body">
      <%= form_with url: admin_site_settings_path, method: :patch do |f| %>
        <div style="margin-bottom:12px; background:#1e1e1e; border:1px solid #333; padding:10px;">
          <label style="display:flex; align-items:flex-start; gap:8px; font-size:11px; color:#cfcfcf; cursor:pointer;">
            <input type="checkbox" name="maintenance_mode" value="1" <%= @maintenance ? "checked" : "" %> style="width:14px; height:14px; margin-top:1px;">
            <span>
              <strong>Enable Maintenance Mode</strong>
              <span style="display:block; color:#888; font-size:10px; margin-top:2px;">
                When enabled, all non-admin users see a maintenance page. Admins can still access the site normally.
              </span>
            </span>
          </label>
        </div>
        <div style="margin-bottom:12px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Maintenance Message:</label>
          <textarea name="maintenance_message" rows="3" style="width:100%; resize:vertical;"><%= @maintenance_message %></textarea>
          <div style="font-size:10px; color:#555; margin-top:2px;">Shown to users when maintenance mode is active.</div>
        </div>
        <% if @maintenance %>
          <div style="background:#3a2a1a; border:1px solid #7a5020; padding:8px 10px; margin-bottom:12px; font-size:11px; color:#e0a030;">
            ⚠ Maintenance mode is currently <strong>ON</strong>. Non-admin users see a maintenance page.
          </div>
        <% end %>
        <%= f.submit "Save Settings", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</div>
