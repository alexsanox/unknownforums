<% content_for :title, "Users" %>

<div class="panel" style="margin-bottom:10px;">
  <div class="panel-header">
    <span>Manage Users</span>
    <span style="font-size:10px; color:#777; font-weight:normal;">Search usernames, old names, email, flags, and notes</span>
  </div>
  <div class="panel-body">
    <%= form_with url: admin_users_path, method: :get, id: "admin-user-search-form", class: "admin-search-form" do |f| %>
      <div class="admin-search-field grow">
        <label>Search</label>
        <%= f.text_field :q, value: params[:q], placeholder: "Username, old name, email, note, flag reason...", id: "admin-user-search-input", style: "width:100%;" %>
      </div>
      <div class="admin-search-field">
        <label>Role</label>
        <%= f.select :role, [["Any role", ""]] + User.roles.keys.map { |role| [role.capitalize, role] }, { selected: params[:role] }, style: "min-width:120px;" %>
      </div>
      <div class="admin-search-field">
        <label>Status</label>
        <%= f.select :status, [["Any status", ""], ["Active", "active"], ["Banned", "banned"], ["Flagged", "flagged"]], { selected: params[:status] }, style: "min-width:120px;" %>
      </div>
      <div class="admin-search-actions">
        <%= f.submit "Search", class: "btn btn-primary" %>
        <a href="<%= admin_users_path %>" class="btn">Reset</a>
      </div>
    <% end %>
  </div>
</div>

<div class="panel">
  <table>
    <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;">
      <th style="padding:4px 10px; text-align:left;">User</th>
      <th style="padding:4px 10px; text-align:left;">Email</th>
      <th style="padding:4px 10px; text-align:left;">Old Names</th>
      <th style="padding:4px 10px; text-align:center;">Role</th>
      <th style="padding:4px 10px; text-align:left;">Staff Of</th>
      <th style="padding:4px 10px; text-align:center;">Rep</th>
      <th style="padding:4px 10px; text-align:center;">Posts</th>
      <th style="padding:4px 10px; text-align:center;">Status</th>
      <th style="padding:4px 10px; text-align:center;">Actions</th>
    </tr>
    <% if @users.empty? %>
      <tr><td colspan="9" style="padding:20px; text-align:center; color:#666; font-size:12px;">No users matched your filters.</td></tr>
    <% end %>
    <% @users.each_with_index do |user, i| %>
      <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
        <td style="padding:7px 10px; font-size:12px;">
          <a href="<%= admin_user_path(user) %>"><%= user.username %></a>
          <div style="font-size:10px; color:#666;">Joined <%= user.created_at.strftime("%m/%d/%y") %></div>
        </td>
        <td style="padding:7px 10px; font-size:11px; color:#888;"><%= user.email.presence || "—" %></td>
        <td style="padding:7px 10px; font-size:10px; color:#777;">
          <% if user.previous_usernames.any? %>
            <%= user.previous_usernames.last(3).join(", ") %>
          <% else %>
            —
          <% end %>
        </td>
        <td style="padding:7px 10px; text-align:center; font-size:11px;">
          <%= user.role.capitalize %>
        </td>
        <td style="padding:7px 10px; font-size:10px; color:#888;">
          <% cats = user.moderated_categories %>
          <% if cats.any? %>
            <%= cats.map(&:name).join(", ") %>
          <% else %>
            <span style="color:#555;">—</span>
          <% end %>
        </td>
        <td style="padding:7px 10px; text-align:center; font-size:12px;"><%= rep_label(user.reputation) %></td>
        <td style="padding:7px 10px; text-align:center; font-size:12px;"><%= user.post_count %></td>
        <td style="padding:7px 10px; text-align:center;">
          <div class="action-group" style="justify-content:center;">
            <% if user.banned? %><span class="badge" style="color:#f08080; border-color:#7a3030;">Banned</span><% end %>
            <% if user.flagged? %><span class="badge badge-pin">Flagged</span><% end %>
            <% unless user.banned? || user.flagged? %><span style="color:#80c080; font-size:11px;">Active</span><% end %>
          </div>
          <% if user.flagged? && user.flag_reason.present? %>
            <div style="font-size:10px; color:#888; margin-top:3px;"><%= truncate(user.flag_reason, length: 32) %></div>
          <% end %>
        </td>
        <td style="padding:7px 10px; text-align:center;">
          <div class="action-group" style="justify-content:center;">
            <a href="<%= edit_admin_user_path(user) %>" class="btn btn-sm">Edit</a>
            <% if user.banned? %>
              <%= button_to "Unban", unban_admin_user_path(user), method: :patch, class: "btn btn-success btn-sm" %>
            <% else %>
              <%= button_to "Ban", ban_admin_user_path(user), method: :patch, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Ban #{user.username}?" } %>
            <% end %>
            <% if user.flagged? %>
              <%= button_to "Unflag", unflag_admin_user_path(user), method: :patch, class: "btn btn-sm" %>
            <% else %>
              <%= button_to "Flag", flag_admin_user_path(user, flag_reason: "Needs admin review"), method: :patch, class: "btn btn-sm" %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </table>
</div>

<div class="toolbar" style="margin-top:8px;">
  <span>Showing <%= @users.size %> users — Page <%= @users.current_page %> of <%= @users.total_pages %></span>
  <div class="action-group">
    <%= link_to_prev_page @users, "← Prev", class: "btn btn-sm" %>
    <%= link_to_next_page @users, "Next →", class: "btn btn-sm" %>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  (() => {
    const form = document.getElementById("admin-user-search-form");
    const input = document.getElementById("admin-user-search-input");
    if (!form || !input) return;

    let timer;
    input.addEventListener("input", () => {
      clearTimeout(timer);
      timer = setTimeout(() => form.requestSubmit(), 450);
    });

    form.querySelectorAll("select").forEach((select) => {
      select.addEventListener("change", () => form.requestSubmit());
    });
  })();
</script>
