<div class="admin-summary">
  <div class="toolbar" style="margin-bottom:8px;">
    <span><strong style="color:#e0e0e0;">Admin Dashboard</strong></span>
  </div>

  <div class="admin-stats">
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @admin_summary[:users] %></div>
      <div class="admin-stat-label">Users</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @admin_summary[:threads] %></div>
      <div class="admin-stat-label">Threads</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @admin_summary[:posts] %></div>
      <div class="admin-stat-label">Posts</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value" style="color:<%= @admin_summary[:pending_reports] > 0 ? '#f08080' : '#80c080' %>;"><%= @admin_summary[:pending_reports] %></div>
      <div class="admin-stat-label">Pending Reports</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @admin_summary[:files] %></div>
      <div class="admin-stat-label">Files</div>
    </div>
  </div>

  <% active_admin_section = controller_path == "downloads" ? "downloads" : controller_name %>
  <div class="admin-quick-links">
    <a href="<%= admin_forums_path %>" class="btn <%= active_admin_section == 'forums' ? 'btn-primary' : '' %>">Forum Structure</a>
    <a href="<%= admin_categories_path %>" class="btn <%= active_admin_section == 'categories' ? 'btn-primary' : '' %>">Categories</a>
    <a href="<%= admin_subforums_path %>" class="btn <%= active_admin_section == 'subforums' ? 'btn-primary' : '' %>">Subforums</a>
    <a href="<%= downloads_path %>" class="btn <%= active_admin_section == 'downloads' ? 'btn-primary' : '' %>">Downloads</a>
    <a href="<%= admin_users_path %>" class="btn <%= active_admin_section == 'users' ? 'btn-primary' : '' %>">Manage Users</a>
    <a href="<%= admin_reports_path %>" class="btn <%= active_admin_section == 'reports' ? 'btn-primary' : (@admin_summary[:pending_reports] > 0 ? 'btn-danger' : '') %>">Reports</a>
    <a href="<%= admin_attack_events_path %>" class="btn <%= active_admin_section == 'attack_events' ? 'btn-primary' : '' %>">Attack Events</a>
    <a href="<%= admin_file_leaderboard_path %>" class="btn <%= active_admin_section == 'file_leaderboard' ? 'btn-primary' : '' %>">File Leaderboard</a>
    <a href="<%= admin_site_pages_path %>" class="btn <%= active_admin_section == 'site_pages' ? 'btn-primary' : '' %>">Edit Rules / Terms</a>
    <a href="<%= admin_audit_logs_path %>" class="btn <%= active_admin_section == 'audit_logs' ? 'btn-primary' : '' %>">Audit Log</a>
    <a href="<%= admin_ip_bans_path %>" class="btn <%= active_admin_section == 'ip_bans' ? 'btn-primary' : '' %>">IP Bans</a>
    <% if admin? %>
      <a href="<%= admin_site_settings_path %>" class="btn <%= active_admin_section == 'site_settings' ? 'btn-primary' : '' %>" style="<%= SiteSetting.maintenance_mode? ? 'border-color:#f0a030; color:#f0a030;' : '' %>">Site Settings<% if SiteSetting.maintenance_mode? %> <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><% end %></a>
    <% end %>
  </div>
</div>
