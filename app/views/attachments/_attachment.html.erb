<%
  approved   = attachment.approved?
  is_video   = attachment.video?
  is_image   = attachment.image?
  can_manage = logged_in? && (current_user == attachment.user || moderator_or_admin?)
  can_mod    = logged_in? && moderator_or_admin?
%>
<div style="background:var(--bg3); border:1px solid var(--border); border-left:3px solid <%= approved ? '#3d9faf' : '#c06060' %>; border-radius:3px; margin-bottom:6px; overflow:hidden;">

  <%# ── Video player ── %>
  <% if is_video %>
    <div style="background:#000; position:relative;">
      <video data-controller="video-player"
             data-video-player-src-value="<%= rails_blob_url(attachment.file) %>"
             data-video-player-type-value="<%= attachment.content_type %>"
             style="width:100%; display:block;"
             playsinline preload="metadata">
      </video>
    </div>
    <div style="padding:8px 10px; display:flex; align-items:center; justify-content:space-between; gap:8px; flex-wrap:wrap;">
      <div style="display:flex; align-items:center; gap:8px; min-width:0;">
        <svg width="14" height="14" fill="none" stroke="var(--accent)" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <span style="font-size:11px; color:var(--text-bright); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= attachment.filename %></span>
        <span style="font-size:10px; color:var(--text-muted);">(<%= attachment.human_size %>)</span>
        <% if approved %>
          <span style="font-size:9px; font-weight:bold; color:#3d9faf; letter-spacing:.04em;">VERIFIED</span>
        <% else %>
          <span style="font-size:9px; font-weight:bold; color:#e0a030; letter-spacing:.04em;">UNVERIFIED</span>
        <% end %>
        <%= render "attachments/vt_badge", attachment: attachment %>
      </div>
      <div style="display:flex; gap:4px; flex-shrink:0;">
        <%= render "attachments/mod_actions", attachment: attachment, approved: approved, can_manage: can_manage, can_mod: can_mod %>
      </div>
    </div>

  <%# ── Image ── %>
  <% elsif is_image %>
    <div style="padding:8px 10px;">
      <%= image_tag rails_blob_url(attachment.file),
            style: "max-width:100%; max-height:360px; border-radius:2px; border:1px solid var(--border); display:block;",
            loading: "lazy" %>
      <div style="margin-top:6px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:6px;">
        <div style="display:flex; align-items:center; gap:8px; font-size:10px; color:var(--text-muted);">
          <span style="color:var(--text-dim);"><%= attachment.filename %></span>
          <span>(<%= attachment.human_size %>)</span>
          <% if approved %>
            <span style="color:#3d9faf; font-weight:bold;">Verified</span>
          <% else %>
            <span style="color:#e0a030; font-weight:bold;">Unverified</span>
          <% end %>
          <%= render "attachments/vt_badge", attachment: attachment %>
        </div>
        <div style="display:flex; gap:4px;">
          <%= render "attachments/mod_actions", attachment: attachment, approved: approved, can_manage: can_manage, can_mod: can_mod %>
        </div>
      </div>
    </div>

  <%# ── File ── %>
  <% else %>
    <div style="padding:8px 10px; display:flex; align-items:center; gap:10px;">
      <%= render "attachments/file_icon", attachment: attachment %>
      <div style="flex:1; min-width:0;">
        <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
          <a href="<%= download_attachment_path(attachment) %>" style="font-size:12px; color:var(--link); font-weight:bold;" data-turbo="false"><%= attachment.filename %></a>
          <% if approved %>
            <span style="font-size:9px; font-weight:bold; color:#3d9faf; letter-spacing:.04em;">VERIFIED</span>
          <% else %>
            <span style="font-size:9px; font-weight:bold; color:#e0a030; letter-spacing:.04em;">UNVERIFIED</span>
          <% end %>
          <%= render "attachments/vt_badge", attachment: attachment %>
        </div>
        <div style="font-size:10px; color:var(--text-muted); margin-top:2px;">
          v<%= attachment.version %> &mdash; <%= attachment.human_size %> &mdash; <%= attachment.download_count %> downloads
          <% if attachment.root_attachment.versions.any? %>
            &mdash; <a href="<%= new_version_attachment_path(attachment.root_attachment) %>" style="color:var(--text-muted);"><%= attachment.root_attachment.versions.count + 1 %> versions</a>
          <% end %>
        </div>
      </div>
      <div style="display:flex; gap:4px; flex-shrink:0; align-items:center;">
        <a href="<%= attachment_path(attachment) %>" class="btn btn-sm">Details</a>
        <a href="<%= download_attachment_path(attachment) %>" class="btn btn-sm" data-turbo="false" style="display:flex; align-items:center; gap:4px;">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
        <% if logged_in? && (current_user == attachment.root_attachment.user || moderator_or_admin?) %>
          <a href="<%= new_version_attachment_path(attachment.root_attachment) %>" class="btn btn-sm" title="Upload new version" style="display:flex; align-items:center; gap:4px;">
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
            Update
          </a>
        <% end %>
        <%= render "attachments/mod_actions", attachment: attachment, approved: approved, can_manage: can_manage, can_mod: can_mod %>
      </div>
    </div>
  <% end %>
</div>
