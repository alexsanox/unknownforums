<% if can_mod %>
  <% if approved %>
    <%= button_to unapprove_attachment_path(attachment), method: :patch,
          style: "display:inline-flex; align-items:center; gap:4px; padding:3px 8px; font-size:10px; background:#2a2a2a; color:#e0a030; border:1px solid #e0a030; border-radius:2px; cursor:pointer; letter-spacing:.03em;",
          data: { turbo_confirm: "Revoke verification for this file?" } do %>
      <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      Revoke
    <% end %>
  <% else %>
    <%= button_to approve_attachment_path(attachment), method: :patch,
          style: "display:inline-flex; align-items:center; gap:4px; padding:3px 8px; font-size:10px; background:#1a3a1a; color:#60c060; border:1px solid #60c060; border-radius:2px; cursor:pointer; letter-spacing:.03em;" do %>
      <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      Approve
    <% end %>
  <% end %>
<% end %>

<% if can_manage %>
  <%= button_to attachment_path(attachment), method: :delete,
        style: "display:inline-flex; align-items:center; gap:4px; padding:3px 8px; font-size:10px; background:#3a1a1a; color:#d06060; border:1px solid #d06060; border-radius:2px; cursor:pointer; letter-spacing:.03em;",
        data: { turbo_confirm: "Permanently delete this attachment?" } do %>
    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
    Delete
  <% end %>
<% end %>
