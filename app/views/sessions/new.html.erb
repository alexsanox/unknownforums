<% content_for :title, "Login" %>
<% meta_description "Log in to #{forum_name} to join the discussion." %>
<% noindex_page %>

<div style="max-width:400px; margin:20px auto;">
  <div style="background:#242424; border:1px solid #444;">
    <div style="background:#303030; border-bottom:1px solid #444; padding:6px 10px; font-size:13px; font-weight:bold; color:#e0e0e0;">
      Login
    </div>
    <div style="padding:16px;">
      <p style="font-size:11px; color:#888; line-height:1.5; margin-top:0;">
        If email 2FA is enabled on your profile, a login code will be sent after your password is accepted.
      </p>
      <%= form_with url: login_path do |f| %>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Username:</label>
          <%= f.text_field :username, style: "width:100%;", autocomplete: "username" %>
        </div>
        <div style="margin-bottom:12px;">
          <label style="display:block; font-size:11px; color:#888; margin-bottom:3px;">Password:</label>
          <%= f.password_field :password, style: "width:100%;", autocomplete: "current-password" %>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <%= f.submit "Login", class: "btn btn-primary", style: "padding:4px 20px;" %>
          <a href="<%= register_path %>" style="font-size:11px; color:#888;">Don't have an account? Register</a>
        </div>
      <% end %>
    </div>
  </div>
</div>
