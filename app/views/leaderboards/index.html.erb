<% content_for :title, "Leaderboard" %>
<% meta_description "Top members, files, uploads, reputation, and downloads on #{forum_name}." %>
<% canonical_url leaderboard_url %>

<div class="panel" style="margin-bottom:12px;">
  <div class="panel-header">Community Leaderboard</div>
  <div class="panel-body" style="font-size:12px; color:#aaa; line-height:1.6;">
    See the top members by posts, reputation, file uploads, and downloads.
  </div>
</div>

<div style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:12px;">
  <div class="panel">
    <div class="panel-header">Top Posters</div>
    <div class="panel-body" style="padding:0;">
      <table>
        <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;"><th>#</th><th style="text-align:left;">User</th><th style="text-align:center;">Posts</th></tr>
        <% @top_posters.each_with_index do |user, i| %>
          <tr style="background:<%= i.even? ? '#242424' : '#202020' %>;"><td><%= i + 1 %></td><td><a href="<%= user_path(user) %>"><%= user.username %></a></td><td style="text-align:center; font-weight:bold;"><%= user.posts_count %></td></tr>
        <% end %>
      </table>
    </div>
  </div>

  <div class="panel">
    <div class="panel-header">Top Reputation</div>
    <div class="panel-body" style="padding:0;">
      <table>
        <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;"><th>#</th><th style="text-align:left;">User</th><th style="text-align:center;">Reputation</th></tr>
        <% @top_reputation.each_with_index do |user, i| %>
          <tr style="background:<%= i.even? ? '#242424' : '#202020' %>;"><td><%= i + 1 %></td><td><a href="<%= user_path(user) %>"><%= user.username %></a></td><td style="text-align:center; font-weight:bold;"><%= rep_label(user.reputation) %></td></tr>
        <% end %>
      </table>
    </div>
  </div>

  <div class="panel">
    <div class="panel-header">Top Uploaders</div>
    <div class="panel-body" style="padding:0;">
      <table>
        <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;"><th>#</th><th style="text-align:left;">User</th><th style="text-align:center;">Files</th></tr>
        <% @top_uploaders.each_with_index do |(user, count), i| %>
          <tr style="background:<%= i.even? ? '#242424' : '#202020' %>;"><td><%= i + 1 %></td><td><a href="<%= user_path(user) %>"><%= user.username %></a></td><td style="text-align:center; font-weight:bold;"><%= count %></td></tr>
        <% end %>
      </table>
    </div>
  </div>

  <div class="panel">
    <div class="panel-header">Top File Downloads</div>
    <div class="panel-body" style="padding:0;">
      <table>
        <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;"><th>#</th><th style="text-align:left;">User</th><th style="text-align:center;">Downloads</th></tr>
        <% @top_downloaders.each_with_index do |(user, count), i| %>
          <tr style="background:<%= i.even? ? '#242424' : '#202020' %>;"><td><%= i + 1 %></td><td><a href="<%= user_path(user) %>"><%= user.username %></a></td><td style="text-align:center; font-weight:bold;"><%= count %></td></tr>
        <% end %>
      </table>
    </div>
  </div>
</div>

<div class="panel" style="margin-top:12px;">
  <div class="panel-header">Top Downloaded Files</div>
  <div class="panel-body" style="padding:0;">
    <table>
      <tr style="background:#222; font-size:10px; color:#666; text-transform:uppercase;"><th>#</th><th style="text-align:left;">File</th><th style="text-align:left;">Uploader</th><th style="text-align:center;">Downloads</th></tr>
      <% @top_files.each_with_index do |attachment, i| %>
        <tr style="background:<%= i.even? ? '#242424' : '#202020' %>;">
          <td><%= i + 1 %></td>
          <td><a href="<%= download_attachment_path(attachment) %>"><%= attachment.filename %></a> <span style="font-size:10px; color:#666;"><%= attachment.human_size %></span></td>
          <td><a href="<%= user_path(attachment.user) %>"><%= attachment.user.username %></a></td>
          <td style="text-align:center; font-weight:bold;"><%= attachment.download_count %></td>
        </tr>
      <% end %>
    </table>
    <% if @top_files.empty? %><div style="padding:20px; text-align:center; color:#666;">No approved files yet.</div><% end %>
  </div>
</div>
