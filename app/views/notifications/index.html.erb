<% content_for :title, "Notifications" %>

<!-- Watched Threads -->
<div class="panel" style="margin-bottom:12px;">
  <div class="panel-header">
    🔔 Watched Threads
    <span style="font-weight:normal; color:#888; font-size:10px; margin-left:6px;"><%= @watched_threads.size %> watched</span>
  </div>
  <% if @watched_threads.any? %>
    <table style="width:100%;">
      <thead>
        <tr style="background:#2a2a2a; border-bottom:1px solid #444;">
          <th style="padding:5px 10px; font-size:10px; color:#888; text-align:left;">Thread</th>
          <th style="padding:5px 10px; font-size:10px; color:#888; text-align:center;">New Posts</th>
          <th style="padding:5px 10px; font-size:10px; color:#888; text-align:left;">Subforum</th>
          <th style="padding:5px 10px; font-size:10px; color:#888; text-align:left;">Last Read</th>
          <th style="padding:5px 10px; font-size:10px; color:#888;"></th>
        </tr>
      </thead>
      <tbody>
        <% @watched_threads.each_with_index do |sub, i| %>
          <% thread = sub.forum_thread %>
          <% has_unread = sub.unread?(thread) %>
          <tr style="background:<%= i.even? ? '#242424' : '#202020' %>; border-top:1px solid #333;">
            <td style="padding:7px 10px; font-size:12px;">
              <% if has_unread %>
                <span style="display:inline-block; width:7px; height:7px; background:#7aabde; border-radius:50%; margin-right:4px; vertical-align:middle;" title="New posts"></span>
              <% end %>
              <a href="<%= forum_thread_path(thread) %>" style="<%= has_unread ? 'font-weight:bold; color:#a8c8f0;' : 'color:#888;' %>">
                <%= truncate(thread.title, length: 60) %>
              </a>
              <% if thread.locked? %>
                <span style="font-size:9px; color:#666; margin-left:4px;">LOCKED</span>
              <% end %>
            </td>
            <td style="padding:7px 10px; text-align:center; font-size:12px;">
              <% if has_unread %>
                <% count = sub.last_read_at ? thread.posts.where("created_at > ?", sub.last_read_at).count : thread.posts_count %>
                <span style="background:#7aabde; color:#000; border-radius:10px; padding:1px 7px; font-size:10px; font-weight:bold;"><%= count %></span>
              <% else %>
                <span style="color:#444;">—</span>
              <% end %>
            </td>
            <td style="padding:7px 10px; font-size:11px; color:#666;">
              <a href="<%= subforum_path(thread.subforum) %>" style="color:#666;"><%= thread.subforum.name %></a>
            </td>
            <td style="padding:7px 10px; font-size:10px; color:#555;">
              <%= sub.last_read_at ? sub.last_read_at.strftime("%m/%d %H:%M") : "Never" %>
            </td>
            <td style="padding:7px 10px; text-align:right;">
              <%= button_to "Unwatch",
                    forum_thread_thread_subscription_path(thread, sub),
                    method: :delete,
                    class: "btn btn-sm",
                    style: "padding:2px 6px; font-size:10px;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="padding:20px; text-align:center; color:#666; font-size:12px;">
      You're not watching any threads. Click <strong>Watch</strong> on any thread to get notified of new replies.
    </div>
  <% end %>
</div>

<!-- Mention Notifications -->
<div class="panel">
  <div class="panel-header">
    � Mentions
    <span style="font-weight:normal; color:#888; font-size:10px; margin-left:6px;"><%= @mentions.size %> recent</span>
  </div>
  <% if @mentions.any? %>
    <% @mentions.each do |n| %>
      <div style="padding:9px 12px; border-top:1px solid #333; display:flex; gap:10px; align-items:flex-start;
                  background:<%= n.read? ? 'transparent' : '#1e2830' %>;">
        <div style="flex:1; min-width:0;">
          <div style="font-size:12px; color:#cfcfcf;"><%= n.message %></div>
          <div style="font-size:10px; color:#666; margin-top:2px;">
            <%= n.created_at.strftime("%m/%d/%Y %I:%M %p") %>
            <% if n.notifiable_type == "Post" && n.notifiable %>
              &mdash; <a href="<%= forum_thread_path(n.notifiable.thread, anchor: "post-#{n.notifiable_id}") %>">Jump to post</a>
            <% end %>
          </div>
        </div>
        <% unless n.read? %>
          <span style="width:7px; height:7px; background:#7aabde; border-radius:50%; flex-shrink:0; margin-top:4px;"></span>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div style="padding:20px; text-align:center; color:#666; font-size:12px;">No mentions yet.</div>
  <% end %>
</div>
